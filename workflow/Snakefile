# =============================================================================

import os
import sys

import snakemake as _snakemake_pkg  # only for __version__ — see SNAKEMAKE_VERSION below

configfile: "config/config.yaml"

# ── Derived paths ─────────────────────────────────────────────────────────────
QUERY_PREFIX  = config["query"]["prefix"]
TARGET_PREFIX = config["target"]["prefix"]
OUTDIR        = config["outdir"]
EVALUE_CUTOFF    = config["blast"]["evalue"]
DS_SAT_THRESHOLD = float(config.get("dS_saturation_threshold", 2.0))
INTER         = f"{OUTDIR}/intermediate"
RESULTS       = f"{OUTDIR}/results"

# Shared file where each tool's rule records its own actually-installed
# version (see workflow/scripts/record_tool_version.py). Deliberately NOT
# declared as a formal Snakemake input/output anywhere: it's written to by
# many different rules over the course of a run (get_rbh once, mafft/
# run_trimmer/codeml once per gene), and Snakemake doesn't support several
# rules sharing one declared output. write_summary reads it via params
# instead — safe in practice because its real declared inputs already
# transitively depend on every rule below having finished first, so this
# file is guaranteed fully populated by the time write_summary runs even
# though Snakemake isn't explicitly tracking that dependency.
VERSIONS_FILE = f"{INTER}/tool_versions.json"

# Path to the version-recorder script, passed explicitly to every rule that
# needs it via params (below) rather than having each script try to derive
# its own location from a snakemake.workflow.basedir-style attribute — that
# attribute isn't a stable, documented part of the script API across
# Snakemake versions, and accessing it defensively still isn't as robust as
# just not needing it in the first place. This mirrors how the existing
# shell-based rules already reference "workflow/scripts/get_rbh.py" as a
# plain path relative to the directory snakemake is invoked from.
RECORD_SCRIPT = "workflow/scripts/record_tool_version.py"

# Captured once, here in the master process that's actually running
# Snakemake — not via a subprocess call from inside some rule's isolated
# --use-conda environment, where `snakemake` itself is usually not
# installed at all and would just report "not found".
SNAKEMAKE_VERSION = getattr(_snakemake_pkg, "__version__", "unknown")

# ── Tool switches (with defaults) ─────────────────────────────────────────────
TOOLS         = config.get("tools", {})
CDS_TOOL      = TOOLS.get("cds_extraction", "anchorwave")
SEARCH_METHOD = TOOLS.get("search_method",  "blast")
TRIMMER       = TOOLS.get("trimmer",        "gblocks")

VALID = {
    "cds_extraction": ["anchorwave", "gffread"],
    "search_method":  ["blast", "diamond"],
    "trimmer":        ["gblocks", "trimal"],
}
for key, val in [("cds_extraction", CDS_TOOL),
                 ("search_method",  SEARCH_METHOD),
                 ("trimmer",        TRIMMER)]:
    if val not in VALID[key]:
        sys.exit(
            f"Config error: tools.{key} = '{val}' is not valid. "
            f"Choose from: {', '.join(VALID[key])}"
        )

# ── Detect input mode per species ─────────────────────────────────────────────
def _has(species, key):
    return key in config[species] and config[species][key]

def _mode(species):
    """
    Detect input mode for a species. Priority: B > C > A.

      Mode A — fasta + gff  : CDS extracted, then translated
      Mode B — faa + fna    : both files supplied, skip all extraction
      Mode C — fna only     : CDS supplied, transeq translates

    Any combination across the two species is valid.
    """
    if _has(species, "faa") and _has(species, "fna"):
        return "B"
    if _has(species, "fna") and not _has(species, "faa"):
        return "C"
    if _has(species, "fasta") and _has(species, "gff"):
        return "A"
    sys.exit(
        f"Config error for '{species}': provide one of:\n"
        f"  (fasta + gff)  — Mode A: genome + GFF\n"
        f"  (faa + fna)    — Mode B: pre-made protein + CDS\n"
        f"  (fna)          — Mode C: CDS nucleotide only"
    )

QUERY_MODE  = _mode("query")
TARGET_MODE = _mode("target")

# ── Resolve FAA and FNA paths ─────────────────────────────────────────────────
def _resolved_faa(species, prefix):
    m = _mode(species)
    if m == "B":
        return config[species]["faa"]
    return f"{INTER}/cds/{prefix}.faa"

def _resolved_fna(species, prefix):
    m = _mode(species)
    if m in ("B", "C"):             # user-supplied FNA used directly
        return config[species]["fna"]
    return f"{INTER}/cds/{prefix}.clean.fna"  # Mode A: cleaned by clean_fna.py

QUERY_FAA  = _resolved_faa("query",  QUERY_PREFIX)
QUERY_FNA  = _resolved_fna("query",  QUERY_PREFIX)
TARGET_FAA = _resolved_faa("target", TARGET_PREFIX)
TARGET_FNA = _resolved_fna("target", TARGET_PREFIX)

# ── Upfront config validation ─────────────────────────────────────────────────
# Catches common config mistakes (typo'd paths, out-of-range values) before
# any rule runs, rather than failing partway through a long BLAST/codeml run
# with a less obvious error. Collects every problem found rather than
# stopping at the first one, so a person fixing config.yaml can address
# everything in one pass instead of hitting them one at a time. This checks
# only the raw, user-supplied paths (config[species]["fasta"/"gff"/"faa"/
# "fna"]) — not QUERY_FAA/QUERY_FNA/etc. above, which for Mode A are
# pipeline-derived outputs that don't exist yet at this point and are not
# supposed to.
_config_errors = []


def _check_file_exists(label, path):
    if path and not os.path.isfile(path):
        _config_errors.append(f"  {label} does not exist: '{path}'")


for _species, _mode_val in (("query", QUERY_MODE), ("target", TARGET_MODE)):
    if _mode_val == "A":
        _check_file_exists(f"{_species}.fasta", config[_species].get("fasta"))
        _check_file_exists(f"{_species}.gff",   config[_species].get("gff"))
    elif _mode_val == "B":
        _check_file_exists(f"{_species}.faa", config[_species].get("faa"))
        _check_file_exists(f"{_species}.fna", config[_species].get("fna"))
    elif _mode_val == "C":
        _check_file_exists(f"{_species}.fna", config[_species].get("fna"))

_min_cov = config["blast"].get("min_cov", 60)
try:
    if not (0 <= float(_min_cov) <= 100):
        _config_errors.append(f"  blast.min_cov = {_min_cov} — must be between 0 and 100")
except (TypeError, ValueError):
    _config_errors.append(f"  blast.min_cov = '{_min_cov}' — must be numeric")

try:
    if float(EVALUE_CUTOFF) <= 0:
        _config_errors.append(f"  blast.evalue = {EVALUE_CUTOFF} — must be a positive number")
except (TypeError, ValueError):
    _config_errors.append(f"  blast.evalue = '{EVALUE_CUTOFF}' — must be numeric")

if DS_SAT_THRESHOLD <= 0:
    _config_errors.append(
        f"  dS_saturation_threshold = {DS_SAT_THRESHOLD} — must be a positive number"
    )

for _label, _prefix_val in (("query.prefix", QUERY_PREFIX), ("target.prefix", TARGET_PREFIX)):
    if not _prefix_val or any(c in _prefix_val for c in " /\\\t\n"):
        _config_errors.append(
            f"  {_label} = '{_prefix_val}' — must be non-empty and contain no "
            f"spaces or path separators (used directly in output filenames)"
        )

for _label, _threads_val in (
    ("blast.threads", config["blast"].get("threads", 1)),
    ("mafft.threads", config.get("mafft", {}).get("threads", 1)),
):
    if not isinstance(_threads_val, int) or _threads_val < 1:
        _config_errors.append(f"  {_label} = {_threads_val} — must be a positive integer")

if _config_errors:
    sys.exit(
        "Config validation failed — fix the following in config.yaml before running:\n"
        + "\n".join(_config_errors)
    )

# ── Helper: read gene list once RBH checkpoint is done ───────────────────────
def get_genes(wildcards):
    rbh_file = checkpoints.get_rbh.get(**wildcards).output.rbh_tsv
    with open(rbh_file) as f:
        lines = [l for l in f.readlines() if not l.startswith("Query")]
    return [f"gene{i+1}" for i, _ in enumerate(lines)]

# ── Final target ──────────────────────────────────────────────────────────────
rule all:
    input:
        f"{RESULTS}/dnds_output.tsv",
        f"{RESULTS}/tables/genes_ds_saturated.tsv",
        f"{RESULTS}/plots/dnds_boxplot.pdf",
        f"{RESULTS}/plots/dnds_violin.pdf",
        f"{RESULTS}/plots/dnds_scatter.pdf",
        f"{RESULTS}/plots/functional_summary.pdf",
        f"{RESULTS}/tables/genes_degenerate_annotated.tsv",
        f"{RESULTS}/plots/pseudogene_evidence.pdf",
        f"{RESULTS}/run_summary.pdf"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 1 — Extract CDS from genome + GFF [Mode A only]
# Tool: anchorwave (default) or gffread
# ─────────────────────────────────────────────────────────────────────────────
if QUERY_MODE == "A":
    rule extract_cds_query:
        input:
            fasta = config["query"]["fasta"],
            gff   = config["query"]["gff"]
        output:
            f"{INTER}/cds/{QUERY_PREFIX}.fna"
        log:
            f"{OUTDIR}/logs/extract_cds_{QUERY_PREFIX}.log"
        params:
            cds_tool = CDS_TOOL
        conda:
            "../envs/anchorwave.yaml"
        script:
            "scripts/extract_cds.py"

if TARGET_MODE == "A":
    rule extract_cds_target:
        input:
            fasta = config["target"]["fasta"],
            gff   = config["target"]["gff"]
        output:
            f"{INTER}/cds/{TARGET_PREFIX}.fna"
        log:
            f"{OUTDIR}/logs/extract_cds_{TARGET_PREFIX}.log"
        params:
            cds_tool = CDS_TOOL
        conda:
            "../envs/anchorwave.yaml"
        script:
            "scripts/extract_cds.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 2 — Sanitise Anchorwave headers [Mode A only]
# (gffread produces clean headers; clean_fna.py only strips anchorwave
# trailing annotations and adds the species prefix)
# ─────────────────────────────────────────────────────────────────────────────
if QUERY_MODE == "A":
    rule clean_fna_query:
        input:
            f"{INTER}/cds/{QUERY_PREFIX}.fna"
        output:
            f"{INTER}/cds/{QUERY_PREFIX}.clean.fna"
        params:
            prefix   = QUERY_PREFIX,
            cds_tool = CDS_TOOL
        script:
            "scripts/clean_fna.py"

if TARGET_MODE == "A":
    rule clean_fna_target:
        input:
            f"{INTER}/cds/{TARGET_PREFIX}.fna"
        output:
            f"{INTER}/cds/{TARGET_PREFIX}.clean.fna"
        params:
            prefix   = TARGET_PREFIX,
            cds_tool = CDS_TOOL
        script:
            "scripts/clean_fna.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 3 — Translate CDS to protein [Modes A and C]
# ─────────────────────────────────────────────────────────────────────────────
if QUERY_MODE in ("A", "C"):
    rule translate_query:
        input:
            f"{INTER}/cds/{QUERY_PREFIX}.clean.fna" if QUERY_MODE == "A"
            else config["query"]["fna"]
        output:
            f"{INTER}/cds/{QUERY_PREFIX}.faa"
        log:
            f"{OUTDIR}/logs/transeq_{QUERY_PREFIX}.log"
        conda:
            "../envs/emboss.yaml"
        script:
            "scripts/fix_transeq.py"

if TARGET_MODE in ("A", "C"):
    rule translate_target:
        input:
            f"{INTER}/cds/{TARGET_PREFIX}.clean.fna" if TARGET_MODE == "A"
            else config["target"]["fna"]
        output:
            f"{INTER}/cds/{TARGET_PREFIX}.faa"
        log:
            f"{OUTDIR}/logs/transeq_{TARGET_PREFIX}.log"
        conda:
            "../envs/emboss.yaml"
        script:
            "scripts/fix_transeq.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 4 — Reciprocal Best Hits
# Tool: blast (default) or diamond
# ─────────────────────────────────────────────────────────────────────────────
checkpoint get_rbh:
    input:
        query  = QUERY_FAA,
        target = TARGET_FAA
    output:
        rbh_tsv   = f"{INTER}/rbh_pairs.tsv",
        blast_fwd = f"{INTER}/blast/fwd.tsv",
        blast_rev = f"{INTER}/blast/rev.tsv"
    params:
        evalue       = EVALUE_CUTOFF,
        threads      = config["blast"]["threads"],
        min_cov      = config["blast"].get("min_cov", 60),
        db_dir       = f"{INTER}/blast/db",
        method       = SEARCH_METHOD,
        version_file = VERSIONS_FILE,
        # Recorded here, where blastp/diamond are actually on PATH — see
        # VERSIONS_FILE comment above for why write_summary can't discover
        # this itself under --use-conda.
        version_cmd  = "blastp -version" if SEARCH_METHOD == "blast" else "diamond version"
    threads:
        config["blast"]["threads"]
    log:
        os.path.abspath(f"{OUTDIR}/logs/get_rbh.log")
    conda:
        "../envs/rbh.yaml"
    shell:
        """
        python3 workflow/scripts/get_rbh.py \
            --query     {input.query} \
            --target    {input.target} \
            --out       {output.rbh_tsv} \
            --blast_fwd {output.blast_fwd} \
            --blast_rev {output.blast_rev} \
            --db_dir    {params.db_dir} \
            --method    {params.method} \
            --evalue    {params.evalue} \
            --min_cov   {params.min_cov} \
            --threads   {params.threads} \
            > {log} 2>&1
        python3 workflow/scripts/record_tool_version.py \
            --file {params.version_file} \
            --tool {params.method} \
            --cmd "{params.version_cmd}" \
            >> {log} 2>&1 || true
        """

# ─────────────────────────────────────────────────────────────────────────────
# STEP 5 — Extract per-gene-pair FAA and FNA sequences
# ─────────────────────────────────────────────────────────────────────────────
rule extract_gene_sequences:
    input:
        pairs = f"{INTER}/rbh_pairs.tsv",
        qfna  = QUERY_FNA,
        tfna  = TARGET_FNA,
        qfaa  = QUERY_FAA,
        tfaa  = TARGET_FAA
    output:
        fna = f"{INTER}/input/{{gene}}.fna",
        faa = f"{INTER}/input/{{gene}}.faa"
    params:
        idx = lambda wc: int(wc.gene.replace("gene", ""))
    shell:
        """
        python3 workflow/scripts/extract_gene_pair.py \
            --pairs   {input.pairs} \
            --idx     {params.idx} \
            --qfna    {input.qfna} \
            --tfna    {input.tfna} \
            --qfaa    {input.qfaa} \
            --tfaa    {input.tfaa} \
            --out_fna {output.fna} \
            --out_faa {output.faa}
        """

# ─────────────────────────────────────────────────────────────────────────────
# STEP 6 — Protein alignment (MAFFT)
# ─────────────────────────────────────────────────────────────────────────────
rule mafft:
    input:
        f"{INTER}/input/{{gene}}.faa"
    output:
        f"{INTER}/aligns/{{gene}}.aln"
    log:
        f"{OUTDIR}/logs/mafft/{{gene}}.log"
    params:
        threads      = config["mafft"]["threads"],
        version_file = VERSIONS_FILE
    threads:
        config["mafft"]["threads"]
    conda:
        "../envs/mafft.yaml"
    shell:
        """
        mafft --auto --thread {params.threads} {input} > {output} 2>{log}
        python3 workflow/scripts/record_tool_version.py \
            --file {params.version_file} --tool mafft --cmd "mafft --version" \
            >> {log} 2>&1 || true
        """

# ─────────────────────────────────────────────────────────────────────────────
# STEP 7 — Codon alignment (pal2nal)
# ─────────────────────────────────────────────────────────────────────────────
rule pal2nal:
    input:
        aln = f"{INTER}/aligns/{{gene}}.aln",
        fna = f"{INTER}/input/{{gene}}.fna"
    output:
        f"{INTER}/aligns/{{gene}}.pal2nal"
    log:
        f"{OUTDIR}/logs/pal2nal/{{gene}}.log"
    conda:
        "../envs/pal2nal.yaml"
    shell:
        "pal2nal.pl {input.aln} {input.fna} -nogap -output fasta > {output} 2>{log}"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 8 — Alignment trimming
# Tool: gblocks (default) or trimal
# Output filename is always {gene}.pal2nal-gb1.fa regardless of tool
# ─────────────────────────────────────────────────────────────────────────────
rule trim_alignment:
    input:
        f"{INTER}/aligns/{{gene}}.pal2nal"
    output:
        f"{INTER}/aligns/{{gene}}.pal2nal-gb1.fa"
    log:
        f"{OUTDIR}/logs/trimmer/{{gene}}.log"
    params:
        trimmer       = TRIMMER,
        version_file  = VERSIONS_FILE,
        record_script = RECORD_SCRIPT
    conda:
        "../envs/trimmer.yaml"
    script:
        "scripts/run_trimmer.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 9 — dN/dS estimation (run_codeml.py)
# ─────────────────────────────────────────────────────────────────────────────
rule codeml:
    input:
        aln = f"{INTER}/aligns/{{gene}}.pal2nal-gb1.fa",
        ctl = "config/codeml.ctl"
    output:
        txt = f"{INTER}/codeml/{{gene}}/{{gene}}_codeml.txt"
    log:
        f"{OUTDIR}/logs/codeml/{{gene}}.log"
    params:
        workdir       = f"{INTER}/codeml/{{gene}}",
        version_file  = VERSIONS_FILE,
        record_script = RECORD_SCRIPT
    conda:
        "../envs/paml.yaml"
    script:
        "scripts/run_codeml.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 10 — Parse codeml outputs and collate into final results table
# ─────────────────────────────────────────────────────────────────────────────
def all_codeml_outputs(wildcards):
    genes = get_genes(wildcards)
    return expand(f"{INTER}/codeml/{{gene}}/{{gene}}_codeml.txt", gene=genes)

rule collate_results:
    input:
        codeml_outputs = all_codeml_outputs,
        rbh_tsv        = f"{INTER}/rbh_pairs.tsv"
    output:
        f"{RESULTS}/dnds_output.tsv",
        f"{RESULTS}/tables/genes_ds_saturated.tsv"
    script:
        "scripts/collate_results.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 11 — Visualisation and functional classification (plot_results.py)
#
# Produces four PDF plots and ten TSV gene-list tables.
# Runs automatically after collate_results.
# ─────────────────────────────────────────────────────────────────────────────
rule plot_results:
    input:
        tsv = f"{RESULTS}/dnds_output.tsv"
    output:
        boxplot    = f"{RESULTS}/plots/dnds_boxplot.pdf",
        violin     = f"{RESULTS}/plots/dnds_violin.pdf",
        scatter    = f"{RESULTS}/plots/dnds_scatter.pdf",
        summary    = f"{RESULTS}/plots/functional_summary.pdf",
        degenerate = f"{RESULTS}/tables/genes_degenerate.tsv"
    params:
        plots_dir          = f"{RESULTS}/plots",
        tables_dir         = f"{RESULTS}/tables",
        diagonal_tolerance = 0.10
    log:
        f"{OUTDIR}/logs/plot_results.log"
    conda:
        "../envs/plotting.yaml"
    script:
        "scripts/plot_results.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 12 — Pseudogene sequence evidence check (check_pseudogenes.py)
#
# For each degenerate candidate (ω ≥ 1), checks the CDS nucleotide sequences
# for premature stop codons and frameshifts — two classic hallmarks of
# pseudogenisation. Works in all input modes since FNA files are always
# available by this stage of the pipeline.
# ─────────────────────────────────────────────────────────────────────────────
rule check_pseudogenes:
    input:
        degenerate = f"{RESULTS}/tables/genes_degenerate.tsv"
    output:
        annotated_tsv = f"{RESULTS}/tables/genes_degenerate_annotated.tsv",
        evidence_pdf  = f"{RESULTS}/plots/pseudogene_evidence.pdf"
    params:
        input_dir = f"{INTER}/input"
    log:
        f"{OUTDIR}/logs/check_pseudogenes.log"
    conda:
        "../envs/plotting.yaml"
    script:
        "scripts/check_pseudogenes.py"

# ─────────────────────────────────────────────────────────────────────────────
# STEP 13 — Run summary report (write_summary.py)
#
# Collates key statistics from all previous steps into a single PDF report:
# run metadata, gene pair counts at each filter stage, dN/dS summary
# statistics, functional classification, dS saturation, and pseudogene
# evidence. Runs after all other steps are complete.
# ─────────────────────────────────────────────────────────────────────────────
rule write_summary:
    input:
        dnds_tsv      = f"{RESULTS}/dnds_output.tsv",
        saturated_tsv = f"{RESULTS}/tables/genes_ds_saturated.tsv",
        annotated_tsv = f"{RESULTS}/tables/genes_degenerate_annotated.tsv",
        rbh_tsv       = f"{INTER}/rbh_pairs.tsv"
    output:
        f"{RESULTS}/run_summary.pdf"
    params:
        query_prefix      = QUERY_PREFIX,
        target_prefix     = TARGET_PREFIX,
        query_mode        = QUERY_MODE,
        target_mode       = TARGET_MODE,
        cds_tool          = CDS_TOOL,
        search_method     = SEARCH_METHOD,
        trimmer           = TRIMMER,
        evalue            = EVALUE_CUTOFF,
        ds_sat_threshold  = DS_SAT_THRESHOLD,
        version_file      = VERSIONS_FILE,
        snakemake_version = SNAKEMAKE_VERSION
    log:
        f"{OUTDIR}/logs/write_summary.log"
    conda:
        "../envs/plotting.yaml"
    script:
        "scripts/write_summary.py"
